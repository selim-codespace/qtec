# PostgreSQL connection string
# Supabase example:
# DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require"
# Local PostgreSQL example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qtech?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/qtech?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qtech?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/qtech?schema=public"
ADMIN_PASSWORD="admin_qtech"
